datasource db {
  provider = "postgresql"
}
generator client {
  provider = "prisma-client-js"
}

model Task {
  id          String   @id
  title       String
  description String
  completed   Boolean  @default(false)
  status      String   @default("todo")
  createdAt   DateTime @default(now())
  priority    String?
  dueDate     DateTime?
}
